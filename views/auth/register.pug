extends ../layout

block content
  .auth-page
    .auth-card
      .auth-card__header
        h1.auth-card__title Đăng ký tài khoản
        p.auth-card__sub Tham gia để đặt tour dễ dàng hơn

      form.auth-form(action="/register" method="POST")
        .form-row
          .form-group.form-group--half
            label(for="fullname") 
              | Họ và tên
              span.required *
            input#fullname.form-control(
              type="text" name="fullname"
              placeholder="Nguyễn Văn A"
              required
            )
          .form-group.form-group--half
            label(for="email") 
              | Email
              span.required *
            input#email.form-control(
              type="email" name="email"
              placeholder="example@email.com"
              required
            )
        .form-group
          label(for="phone") Số điện thoại
          input#phone.form-control(
            type="tel" name="phone"
            placeholder="Nhập số điện thoại"
          )
          .form-hint
            p [Nhập đúng 10 chữ số -Không bắt buộc]
        .form-group
          label(for="password") 
            | Mật khẩu
            span.required *
          input#password.form-control(
            type="password" name="password"
            placeholder="Nhập mật khẩu"
            required minlength="8"
          )
          .password-strength
            .password-strength__bar
              .password-strength__progress(id="passwordBar")
          .form-hint
            p Từ 6 - 18 ký tự
            ul
              li#hint-length Ít nhất phải bao gồm cả chữ số, chữ cái.
              li#hint-special Có thể bao gồm ký tự đặc biệt
        .form-group
          label(for="confirmPassword") 
            | Xác nhận mật khẩu
            span.required *
          input#confirmPassword.form-control(
            type="password" name="confirmPassword"
            placeholder="Nhập lại mật khẩu"
            required
          )
        button.btn.btn--primary.btn--block(type="submit") Tạo tài khoản

      .auth-card__footer
        | Đã có tài khoản?&nbsp;
        a(href="/login") Đăng nhập