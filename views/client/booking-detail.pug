extends ../layout

block content
  .container
    .booking-detail-page

      .booking-detail-header
        h1 Đơn đặt ##{booking.id}
        span(class=`badge badge--${booking.status} badge--lg`)
          = {pending:'Chờ xác nhận',confirmed:'Đã xác nhận',cancelled:'Đã hủy',completed:'Hoàn thành'}[booking.status]

      .booking-detail-grid

        .detail-card
          h3.detail-card__title Thông tin tour
          .summary-row
            span Tour
            strong: a(href=`/tours/${booking.tour_slug}`)= booking.tour_name
          .summary-row
            span Ngày khởi hành
            strong= formatDate(booking.start_date)
          .summary-row
            span Ngày về
            strong= formatDate(booking.end_date)
          .summary-row
            span Điểm khởi hành
            strong= booking.departure_location

        .detail-card
          h3.detail-card__title Thông tin liên hệ
          .summary-row
            span Họ tên
            strong= booking.contact_name
          .summary-row
            span Điện thoại
            strong= booking.contact_phone
          .summary-row
            span Email
            strong= booking.contact_email
          if booking.special_request
            .summary-row
              span Yêu cầu
              strong= booking.special_request

        .detail-card
          h3.detail-card__title Thanh toán

          .summary-row
            span Người lớn
            strong #{booking.adult_count} × #{formatPrice(booking.price_adult)}

          .summary-row
            span Trẻ em
            strong #{booking.child_count} × #{formatPrice(booking.price_child)}

          .summary-row.summary-row--total
            span Tổng tiền
            strong.price= formatPrice(booking.total_price)

          .summary-row
            span Phương thức
            strong= booking.payment_method === 'vnpay' ? 'VNPay' : 'Tiền mặt'

          .summary-row
            span Trạng thái thanh toán
            span(class=`badge badge--${booking.payment_status}`)
              = {pending:'Chưa thanh toán',success:'Đã thanh toán',failed:'Thất bại'}[booking.payment_status]

          .payment-actions(style="margin-top:16px")
            
            //- Cho phép hiện nút khi payment_status là 'pending' HOẶC 'failed'
            if booking.payment_method === 'vnpay' && (booking.payment_status === 'pending' || booking.payment_status === 'failed') && booking.status === 'pending'
              
              .vnpay-timer-box(data-created-at=booking.created_at, style="background:#fff3cd; color:#856404; padding:10px; border-radius:5px; margin-bottom:15px; text-align:center;")
                p(style="margin:0; font-weight:bold;") ⏳ Thời gian giữ chỗ còn lại: 
                  span#countdown-clock(style="color:red; font-size:1.1em;") Đang tính...
              
              //- Đổi text linh hoạt: Nếu failed thì hiện "Thanh toán lại"
              a#btn-vnpay-submit.btn.btn--primary.btn--block(href=`/payment/vnpay/${booking.id}`) 
                if booking.payment_status === 'failed'
                  | 🔄 Thanh toán lại qua VNPay
                else
                  | Thanh toán ngay qua VNPay

            // CASH
            if booking.payment_method === 'cash' && booking.status === 'pending'
              .info-box(style="background:#d1ecf1; color:#0c5460; padding:15px; border-radius:5px;")
                p(style="font-weight:bold; margin-bottom:5px;")
                  | ℹ️ Đơn đặt của bạn đang chờ xác nhận.
                p(style="margin:0;")
                  | Vui lòng đến văn phòng thanh toán tiền mặt trong vòng 
                  strong 24 giờ.
                  |  Sau thời gian này, hệ thống sẽ tự động hủy giữ chỗ của bạn.

            // SUCCESS
            if booking.payment_status === 'success'
              .tip-box
                p ✓ Đã thanh toán thành công
                if booking.paid_at
                  p Thời gian: #{formatDate(booking.paid_at)}

            // BUTTON HỖ TRỢ (FIX INDENT)
            if booking.status === 'confirmed'
              button.btn.btn--outline-danger.btn--block(
                type="button"
                onclick="document.getElementById('cancelPolicyModal').style.display='block'"
                style="margin-top:10px;"
              ) ⚠️ Hỗ trợ Hủy / Dời ngày đi

      // ACTIONS
      .booking-detail-actions
        a.btn.btn--outline(href="/my-bookings") ← Quay lại

        if booking.status === 'pending'
          form(
            action=`/my-bookings/${booking.id}/cancel?_method=PUT`
            method="POST"
            data-confirm="Bạn chắc chắn muốn hủy đơn này?"
          )
            input(type="hidden" name="_csrf" value=csrfToken)
            button.btn.btn--danger(type="submit") Hủy đơn

  #cancelPolicyModal.modal(
    style="display:none; position:fixed; z-index:999; left:0; top:0; width:100%; height:100%; background-color:rgba(0,0,0,0.6); backdrop-filter:blur(4px);"
  )
    .modal-content(
      style="background-color:#fff; margin:8% auto; padding:0; width:90%; max-width:480px; border-radius:12px; position:relative; box-shadow:0 20px 60px rgba(0,0,0,0.3); overflow:hidden;"
    )
      .modal-header(
        style="background:linear-gradient(135deg, #d32f2f 0%, #b71c1c 100%); padding:20px 24px; color:#fff;"
      )
        span.close-btn(
          onclick="document.getElementById('cancelPolicyModal').style.display='none'"
          style="position:absolute; right:20px; top:18px; font-size:28px; cursor:pointer; color:rgba(255,255,255,0.8); transition:color 0.2s;"
          onmouseover="this.style.color='#fff'"
          onmouseout="this.style.color='rgba(255,255,255,0.8)'"
        ) &times;
        h3(style="margin:0; font-size:18px; font-weight:600;") Quy định Hủy / Đổi ngày tour

      .modal-body(style="padding:24px;")
        p(style="font-size:14px; color:#666; margin:0 0 20px 0; line-height:1.6;")
          | Do đặc thù dịch vụ du lịch, hệ thống không hỗ trợ tự động hủy đơn.

        .policy-list(style="margin-bottom:24px;")
          .policy-item(style="display:flex; align-items:center; padding:12px; background:#f8f9fa; border-radius:8px; margin-bottom:10px; border-left:4px solid #4caf50;")
            span(style="font-size:20px; margin-right:12px;") 🟢
            div
              div(style="font-weight:600; color:#2e7d32; font-size:14px;") Trước 5 ngày
              div(style="font-size:13px; color:#666;") Hoàn tiền 100%
          .policy-item(style="display:flex; align-items:center; padding:12px; background:#f8f9fa; border-radius:8px; margin-bottom:10px; border-left:4px solid #ff9800;")
            span(style="font-size:20px; margin-right:12px;") 🟡
            div
              div(style="font-weight:600; color:#ef6c00; font-size:14px;") 2-5 ngày
              div(style="font-size:13px; color:#666;") Phí hủy 50%
          .policy-item(style="display:flex; align-items:center; padding:12px; background:#f8f9fa; border-radius:8px; border-left:4px solid #f44336;")
            span(style="font-size:20px; margin-right:12px;") 🔴
            div
              div(style="font-weight:600; color:#c62828; font-size:14px;") Dưới 48 giờ
              div(style="font-size:13px; color:#666;") Không hoàn tiền

        .contact-section(style="background:#f5f5f5; border-radius:10px; padding:16px; text-align:center;")
          h4(style="margin:0 0 12px 0; font-size:15px; color:#333; font-weight:600;") Liên hệ CSKH để được hỗ trợ
          p(style="margin:0 0 16px 0; font-size:13px; color:#666;")
            | Cung cấp mã đơn: 
            strong(style="color:#d32f2f; font-size:16px; background:#fff; padding:4px 12px; border-radius:4px; display:inline-block;") ##{booking.id}

          .contact-actions(style="display:flex; gap:12px;")
            a.btn.btn--primary(
              href="https://zalo.me/0345043213"
              target="_blank"
              style="flex:1; text-align:center; background:#0068ff; border:none; padding:12px; border-radius:8px; font-weight:600; display:flex; align-items:center; justify-content:center; gap:6px; text-decoration:none; color:#fff;"
            )
              span 💬
              span Zalo

            a.btn.btn--outline(
              href="tel:0345043213"
              style="flex:1; text-align:center; padding:12px; border-radius:8px; font-weight:600; border:2px solid #d32f2f; color:#d32f2f; display:flex; align-items:center; justify-content:center; gap:6px; text-decoration:none;"
            )
              span 📞
              span Hotline

block scripts
  script.
    document.addEventListener("DOMContentLoaded", function() {
      const timerBox = document.querySelector('.vnpay-timer-box');
      if (!timerBox) return;

      const createdAtStr = timerBox.getAttribute('data-created-at');
      const createdAtTime = new Date(createdAtStr).getTime();
      const expireTime = createdAtTime + (15 * 60 * 1000); 

      const clockEl = document.getElementById('countdown-clock');
      const btnVnpay = document.getElementById('btn-vnpay-submit');

      function updateClock() {
        const now = new Date().getTime();
        const distance = expireTime - now;

        if (distance <= 0) {
          clockEl.innerHTML = "Đã quá hạn thanh toán";
          
          if(btnVnpay) {
            btnVnpay.style.backgroundColor = '#ccc';
            btnVnpay.style.pointerEvents = 'none';
            btnVnpay.innerHTML = "Đơn hàng đã bị hủy do quá hạn";
            btnVnpay.removeAttribute('href'); 
          }
          return true; 
        }

        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);
        
        const mDisplay = minutes < 10 ? "0" + minutes : minutes;
        const sDisplay = seconds < 10 ? "0" + seconds : seconds;
        
        clockEl.innerHTML = mDisplay + ":" + sDisplay;
        return false;
      }

      const isExpiredOnLoad = updateClock();

      if (!isExpiredOnLoad) {
        const countdown = setInterval(function() {
          const isExpiredNow = updateClock();
          
          if (isExpiredNow) {
            clearInterval(countdown);
            setTimeout(() => {
              window.location.reload();
            }, 2000);
          }
        }, 1000);
      }
    });