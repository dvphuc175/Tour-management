extends ../layout

block content
  .container
    .booking-detail-page

      .booking-detail-actions
        a.btn.btn--outline.btn--back(href="/my-bookings")
          +fa('arrow-left')
          |  Quay lại

        //- if bookingStatus.canUserCancelBooking(booking)
        if booking.status === 'pending'
          form(
            action=`/my-bookings/${booking.id}/cancel?_method=PUT`
            method="POST"
            data-confirm="Bạn chắc chắn muốn hủy đơn này?"
          )
            input(type="hidden" name="_csrf" value=csrfToken)
            button.btn.btn--danger(type="submit") Hủy đơn

      .booking-detail-header
        h1 Đơn đặt ##{booking.id}
        //- span(class=bookingStatus.bookingBadgeClass(booking.status, 'badge--lg'))
        //-   = bookingStatus.bookingStatusLabel(booking.status)
        span(class=`badge badge--${booking.status} badge--lg`)
          = {pending:'Chờ xác nhận',confirmed:'Đã xác nhận',cancelled:'Đã hủy',completed:'Hoàn thành'}[booking.status]

      //- if bookingStatus.isCashPendingBooking(booking)
      if booking.payment_method === 'cash' && booking.status === 'pending'
        .info-box.info-box--cash
          .booking-notice__icon
            +fa('info')
          .booking-notice__content
            p.booking-notice__title Đơn đặt của bạn đang chờ xác nhận.
            p
              | Vui lòng đến văn phòng thanh toán tiền mặt trong vòng 
              strong 24 giờ.
              |  Sau thời gian này, hệ thống sẽ tự động hủy giữ chỗ của bạn.

      if booking.payment_status === 'success'
        .tip-box
          .booking-notice__icon
            +fa('check')
          .booking-notice__content
            p.booking-notice__title Đã thanh toán thành công
            if booking.paid_at
              p.booking-notice__meta
                span.booking-notice__meta-label Thời gian
                span.booking-notice__meta-value= formatDate(booking.paid_at)

      

      .booking-detail-grid

        if booking.tour_images && booking.tour_images.length
          .booking-tour-image
            img(src=booking.tour_images[0] alt=booking.tour_name)
        
        .detail-card.detail-card--tour
          h3.detail-card__title Thông tin tour
          .summary-row
            span Tour
            strong: a(href=`/tours/${booking.tour_slug}`)= booking.tour_name
          .summary-row
            span Ngày khởi hành
            strong= formatDate(booking.start_date)
          .summary-row
            span Ngày về
            strong= formatDate(booking.end_date)
          .summary-row
            span Điểm khởi hành
            strong= booking.departure_location

        .detail-card.detail-card--contact
          h3.detail-card__title Thông tin liên hệ
          .summary-row
            span Họ tên
            strong= booking.contact_name
          .summary-row
            span Điện thoại
            strong= booking.contact_phone
          .summary-row
            span Email
            strong= booking.contact_email
          .summary-row
            span Yêu cầu
            strong= booking.special_request || 'Không'

        .detail-card.detail-card--payment
          h3.detail-card__title Thanh toán

          .summary-row
            span Người lớn
            strong #{booking.adult_count} × #{formatPrice(booking.price_adult)}

          .summary-row
            span Trẻ em
            strong #{booking.child_count} × #{formatPrice(booking.price_child)}

          .summary-row.summary-row--total
            span Tổng tiền
            strong.price= formatPrice(booking.total_price)

          .summary-row
            span Phương thức
            strong= booking.payment_method === 'vnpay' ? 'VNPay' : 'Tiền mặt'

          .summary-row
            span Trạng thái thanh toán
            span(class=`badge badge--${booking.payment_status}`)
              = {pending:'Chưa thanh toán',success:'Đã thanh toán',failed:'Thất bại',refunded:'Đã hoàn tiền'}[booking.payment_status]

          if booking.status === 'confirmed'
            button.btn.btn--outline-danger.btn--block.btn--support-cancel(
              type="button"
              onclick="openCancelPolicyModal()"
            )
              +fa('warning')
              |  Hỗ trợ Hủy / Dời ngày đi  

          .payment-actions
            if booking.payment_method === 'vnpay' && (booking.payment_status === 'pending' || booking.payment_status === 'failed') && booking.status === 'pending'
              .vnpay-timer-box(data-created-at=booking.created_at)
                p
                  +fa('clock')
                  |  Thời gian giữ chỗ còn lại: 
                  span#countdown-clock Đang tính...
              a#btn-vnpay-submit.btn.btn--primary.btn--block(href=`/payment/vnpay/${booking.id}`) 
                if booking.payment_status === 'failed'
                  +fa('rotate')
                  |  Thanh toán lại qua VNPay
                else
                  | Thanh toán ngay qua VNPay
  #cancelPolicyModal.modal.modal--policy
    .modal-content
      .modal-header
        span.close-btn(onclick="closeCancelPolicyModal()")
          +fa('xmark')
        h3 Quy định Hủy / Đổi ngày tour

      .modal-body
        p Do đặc thù dịch vụ du lịch, hệ thống không hỗ trợ tự động hủy đơn.

        .policy-list
          .policy-item.policy-item--green
            span.policy-item__icon
              +fa('circle')
            div
              .policy-item__title.policy-item__title--green Trước 5 ngày
              .policy-item__desc Hoàn tiền 100%
          .policy-item.policy-item--orange
            span.policy-item__icon
              +fa('circle')
            div
              .policy-item__title.policy-item__title--orange 2-5 ngày
              .policy-item__desc Phí hủy 50%
          .policy-item.policy-item--red
            span.policy-item__icon
              +fa('circle')
            div
              .policy-item__title.policy-item__title--red Dưới 48 giờ
              .policy-item__desc Không hoàn tiền

        .contact-section
          h4 Liên hệ CSKH để được hỗ trợ
          p
            | Cung cấp mã đơn: 
            strong.contact-section__booking-id ##{booking.id}

          .contact-actions
            a.btn.btn--zalo-contact(href="https://zalo.me/0345043213" target="_blank")
              +fa('comment')
              span Zalo
            a.btn.btn--hotline-contact(href="tel:0345043213")
              +fa('phone')
              span Hotline

block scripts
  script.
    function openCancelPolicyModal() {
      document.getElementById('cancelPolicyModal').classList.add('is-open');
    }
    function closeCancelPolicyModal() {
      document.getElementById('cancelPolicyModal').classList.remove('is-open');
    }

    document.addEventListener("DOMContentLoaded", function() {
      const timerBox = document.querySelector('.vnpay-timer-box');
      if (!timerBox) return;

      const createdAtStr = timerBox.getAttribute('data-created-at');
      const createdAtTime = new Date(createdAtStr).getTime();
      const expireTime = createdAtTime + (15 * 60 * 1000); 

      const clockEl = document.getElementById('countdown-clock');
      const btnVnpay = document.getElementById('btn-vnpay-submit');

      function updateClock() {
        const now = new Date().getTime();
        const distance = expireTime - now;

        if (distance <= 0) {
          clockEl.innerHTML = "Đã quá hạn thanh toán";
          
          if(btnVnpay) {
            btnVnpay.classList.add('is-expired');
            btnVnpay.innerHTML = "Đơn hàng đã bị hủy do quá hạn";
            btnVnpay.removeAttribute('href'); 
          }
          return true; 
        }

        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);
        
        const mDisplay = minutes < 10 ? "0" + minutes : minutes;
        const sDisplay = seconds < 10 ? "0" + seconds : seconds;
        
        clockEl.innerHTML = mDisplay + ":" + sDisplay;
        return false;
      }

      const isExpiredOnLoad = updateClock();

      if (!isExpiredOnLoad) {
        const countdown = setInterval(function() {
          const isExpiredNow = updateClock();
          
          if (isExpiredNow) {
            clearInterval(countdown);
            setTimeout(() => {
              window.location.reload();
            }, 2000);
          }
        }, 1000);
      }
    });
