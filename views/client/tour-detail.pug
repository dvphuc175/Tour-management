extends ../layout

block content
  .container
    .tour-detail-layout

      .tour-detail-main

        if tour.images && tour.images.length
          .tour-gallery
            img.tour-gallery__main(
              id="mainImg"
              src=tour.images[0]
              alt=tour.name
            )
            if tour.images.length > 1
              .tour-gallery__thumbs-wrapper
                button.tour-gallery__nav-btn.tour-gallery__nav-btn--prev(
                  type="button"
                  onclick="prevImage()"
                  aria-label="Previous image"
                ) ←
                .tour-gallery__thumbs(id="thumbsContainer")
                  each img, i in tour.images
                    img.tour-gallery__thumb(
                      src=img
                      alt=`Ảnh ${i+1}`
                      class=i===0 ? 'active' : ''
                      onclick=`switchImg(this, '${img}')`
                    )
                button.tour-gallery__nav-btn.tour-gallery__nav-btn--next(
                  type="button"
                  onclick="nextImage()"
                  aria-label="Next image"
                ) →

        .tour-detail-header
          if tour.category_name
            span.tour-card__cat= tour.category_name
          h1.tour-detail__title= tour.name


        // Anchor Navigation
        nav.tour-nav-sticky
          .tour-nav-links
            if sections.overview
              a.tour-nav-link(href="#overview") GIỚI THIỆU
            if sections.highlights
              a.tour-nav-link(href="#highlights") ĐIỂM NỔI BẬT
            if sections.itinerary
              a.tour-nav-link(href="#itinerary") LỊCH TRÌNH
            if schedules.length
              a.tour-nav-link(href="#pricing") BẢNG GIÁ
            if sections.services
              a.tour-nav-link(href="#services") DỊCH VỤ
            if sections.notes
              a.tour-nav-link(href="#notes") LƯU Ý
            a.tour-nav-link(href="#reviews") ĐÁNH GIÁ

        // Content Sections - Continuous Scroll Layout
        .tour-content-sections

          // Section: Overview
          if sections.overview
            section.tour-section#overview
              h3.tour-section__title GIỚI THIỆU
              .tour-overview!= cleanHtml(sections.overview)

          // Section: Highlights
          if sections.highlights
            section.tour-section#highlights
              h3.tour-section__title ĐIỂM NỔI BẬT
              .tour-highlights!= cleanHtml(sections.highlights)

          // Section: Itinerary
          if sections.itinerary
            section.tour-section#itinerary
              h3.tour-section__title LỊCH TRÌNH
              .tour-itinerary
                != cleanHtml(sections.itinerary)

          // Section: Pricing
          if schedules.length
            section.tour-section#pricing
              h3.tour-section__title BẢNG GIÁ
              .tour-pricing-table
                table.schedule-table.schedule-table--expandable
                  thead
                    tr
                      th STT
                      th Ngày khởi hành
                      th Số chỗ còn
                      th Giá từ
                      th Đặc điểm
                      th Hành động
                  tbody
                    each s, index in schedules
                      // Main row
                      tr.schedule-row(data-schedule-id=s.id)
                        td
                          button.schedule-toggle(type="button" onclick=`toggleScheduleDetail('${s.id}')`)
                            span.schedule-toggle__icon.schedule-toggle__icon--plus(id=`icon-plus-${s.id}`) +
                            span.schedule-toggle__icon.schedule-toggle__icon--minus.hidden(id=`icon-minus-${s.id}`) −
                          span.schedule-number= index + 1
                        td
                          strong 📅 #{formatDate(s.start_date)}
                        td
                          if s.available_slots > 0
                            span.text-success= s.available_slots
                          else
                            span.text-danger Hết chỗ
                        td= formatPrice(tour.price_adult)
                        td
                          button.schedule-eye-toggle(type="button" onclick=`togglePriceDetail('${s.id}')` title="Xem chi tiết giá")
                            i.fa-regular.fa-eye.schedule-eye(id=`eye-${s.id}`)
                            i.fa-regular.fa-eye-slash.schedule-eye-slash.hidden(id=`eye-slash-${s.id}`)
                        td
                          if s.available_slots > 0
                            a.btn.btn--primary.btn--sm(href=`/booking/${s.id}`) Chọn
                          else
                            button.btn.btn--outline.btn--sm(disabled) Đã đầy
                      // Expandable price detail row
                      tr.schedule-detail-row.hidden(id=`detail-${s.id}`)
                        td(colspan="6")
                          .schedule-price-detail
                            table.price-detail-table
                              thead
                                tr
                                  th Loại giá/Độ tuổi
                                  th Người lớn (>11 tuổi)
                                  th Trẻ em (5-11 tuổi)
                                  th Trẻ nhỏ (2-5 tuổi)
                                  th Sơ sinh (<2 tuổi)
                              tbody
                                tr
                                  td Giá
                                  td= formatPrice(tour.price_adult)
                                  td= formatPrice(Math.round(tour.price_adult * 0.9))
                                  td= formatPrice(Math.round(tour.price_adult * 0.5))
                                  td 0₫
                                tr
                                  td Phụ thu
                                  td 0₫
                                  td 0₫
                                  td 0₫
                                  td 0₫
                                tr
                                  td Giảm giá
                                  td 0₫
                                  td 0₫
                                  td 0₫
                                  td 0₫

          // Section: Services
          if sections.services
            section.tour-section#services
              h3.tour-section__title DỊCH VỤ 
              .tour-services!= cleanHtml(sections.services)

          // Section: Notes
          if sections.notes
            section.tour-section#notes
              h3.tour-section__title LƯU Ý
              .tour-notes!= cleanHtml(sections.notes)

        //- ── Section Reviews ──────────────────────
        section#reviews.reviews-section

          .reviews-header
            h2 Đánh giá từ khách hàng
            if ratingInfo && ratingInfo.total > 0
              .rating-summary
                span.rating-summary__score= ratingInfo.avg_rating
                span.rating-summary__stars= renderStars(ratingInfo.avg_rating)
                span.rating-summary__count (#{ratingInfo.total} đánh giá)

          //- Form gửi đánh giá
          if user
            if canReview && !hasReviewed
              .review-form-wrap
                h3 Viết đánh giá của bạn
                form.review-form(action="/reviews" method="POST")
                  input(type="hidden" name="tour_id" value=tour.id)
                  input(type="hidden" name="_csrf" value=csrfToken)
                  .star-picker
                    label Chọn số sao
                    .stars-input
                      - for(let i = 5; i >= 1; i--)
                        input(type="radio" name="rating" id=`star${i}` value=`${i}` required)
                        label(for=`star${i}` title=`${i} sao`) ★

                  .form-group
                    label Nhận xét
                    textarea.form-control(
                      name="comment" rows="3"
                      minlength="10" maxlength="1000" required
                      placeholder="Chia sẻ trải nghiệm của bạn (tối thiểu 10 ký tự, tối đa 1000 ký tự)..."
                    )
                  button.btn.btn--primary(type="submit") Gửi đánh giá

            else if hasReviewed
              .review-notice.review-notice--done ✓ Bạn đã đánh giá tour này rồi

            else
              .review-notice Bạn cần hoàn thành tour để có thể đánh giá
          else
            .review-notice
              a(href="/login") Đăng nhập
              |  để gửi đánh giá

          //- Danh sách reviews
          if !reviews || reviews.length === 0
            p.no-reviews Chưa có đánh giá nào. Hãy là người đầu tiên!
          else
            .review-list
              each rv in reviews
                .review-item
                  .review-item__header
                    span.review-item__author= rv.user_name
                    span.review-item__stars= renderStars(rv.rating)
                    span.review-item__date= formatDate(rv.created_at)
                  if rv.comment
                    p.review-item__comment= rv.comment

      aside.tour-booking-box
        if schedules.length === 0
          h3.booking-box__title Lịch trình khởi hành
          p.booking-box__empty Hiện chưa có lịch trình khả dụng.
          a.btn.btn--outline.btn--block(href="/tours") Xem tour khác
        else
          - const nearestSchedule = schedules[0]
          - const upcomingDates = schedules.slice(0, 4)

          .booking-box__price-header
            span.label Giá chỉ từ
            .price= formatPrice(tour.price_adult)

          .booking-box__summary
            .summary-item
              span.icon-calendar 📅 Ngày đi: 
              strong
                each s, index in upcomingDates
                  span #{formatDate(s.start_date).substring(0, 5)}
                  if index < upcomingDates.length - 1
                    | , 
                if schedules.length > 4
                  | ...
            .summary-item
              span.icon-location 📍 Điểm khởi hành: 
              strong #{nearestSchedule.departure_location}
            .summary-item
              span.icon-user 👤 Số chỗ còn nhận (gần nhất): 
              strong.text-danger #{nearestSchedule.available_slots} chỗ

          button.btn.btn--danger.btn--block.btn--outline(type="button" onclick="openScheduleModal()") 
            | XEM LỊCH ĐI CÁC NGÀY KHÁC
          
          a.btn.btn--primary.btn--block(href=`/booking/${nearestSchedule.id}` style="margin-top: 12px;")
            | ĐẶT GIỮ CHỖ NGAY
            small(style="display:block; font-size:11px; font-weight:normal") Đặt ngay ngày #{formatDate(nearestSchedule.start_date)}

  #scheduleModal.modal
    .modal-content
      .modal-header
        h3 Danh sách lịch trình khởi hành
        button.modal-close(onclick="closeScheduleModal()") &times;
      .modal-body
        table.schedule-table
          thead
            tr
              th STT
              th Ngày khởi hành
              th Ngày kết thúc
              th Điểm khởi hành
              th Số chỗ còn
              th Giá người lớn
              th Hành động
          tbody
            each s, index in schedules
              tr
                td= index + 1
                td
                  strong 📅 #{formatDate(s.start_date)}
                td 
                  strong #{formatDate(s.end_date)}
                td #{s.departure_location}
                td
                  if s.available_slots > 0
                    span.text-success= s.available_slots
                  else
                    span.text-danger Hết chỗ
                td= formatPrice(tour.price_adult)
                td
                  if s.available_slots > 0
                    a.btn.btn--primary.btn--sm(href=`/booking/${s.id}`) Chọn
                  else
                    button.btn.btn--outline.btn--sm(disabled) Đã đầy

block scripts
  script(src="/assets/js/tour-gallery.js")
  script.
    function openScheduleModal() {
      document.getElementById('scheduleModal').classList.add('show');
      document.body.style.overflow = 'hidden'; 
    }
    function closeScheduleModal() {
      document.getElementById('scheduleModal').classList.remove('show');
      document.body.style.overflow = 'auto';
    }
    window.onclick = function(event) {
      const modal = document.getElementById('scheduleModal');
      if (event.target == modal) {
        closeScheduleModal();
      }
    }