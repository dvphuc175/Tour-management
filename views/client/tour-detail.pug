extends ../layout

block content
  - const isBookingRestricted = user && (user.role === 'admin' || user.role === 'staff')
  - const canBookTour = !isBookingRestricted
  - const bookingRestrictedMessage = 'Tài khoản quản trị hoặc nhân viên không thể đặt tour'

  .container
    .tour-detail-layout

      .tour-detail-main
        - let sectionAosDelay = 180

        if tour.images && tour.images.length
          .tour-gallery(data-aos="fade-up" data-aos-duration="800")
            img.tour-gallery__main(
              id="mainImg"
              src=tour.images[0]
              alt=tour.name
            )
            if tour.category_name
              span.tour-card__cat.tour-detail__cat= tour.category_name
            if tour.images.length > 1
              .tour-gallery__thumbs-wrapper
                button.tour-gallery__nav-btn.tour-gallery__nav-btn--prev(
                  type="button"
                  onclick="prevImage()"
                  aria-label="Previous image"
                )
                  +fa('chevron-left')
                .tour-gallery__thumbs(id="thumbsContainer")
                  each img, i in tour.images
                    img.tour-gallery__thumb(
                      src=img
                      alt=`Ảnh ${i+1}`
                      class=i===0 ? 'active' : ''
                      onclick=`switchImg(this, '${img}')`
                    )
                button.tour-gallery__nav-btn.tour-gallery__nav-btn--next(
                  type="button"
                  onclick="nextImage()"
                  aria-label="Next image"
                )
                  +fa('chevron-right')

        .tour-detail-header(data-aos="fade-up" data-aos-delay="80")
          h1.tour-detail__title= tour.name


        // Anchor Navigation
        nav.tour-nav-sticky(data-aos="fade-up" data-aos-delay="120")
          .tour-nav-links
            if sections.overview
              a.tour-nav-link(href="#overview") GIỚI THIỆU
            if sections.highlights
              a.tour-nav-link(href="#highlights") ĐIỂM NỔI BẬT
            if sections.itinerary
              a.tour-nav-link(href="#itinerary") LỊCH TRÌNH
            if schedules.length
              a.tour-nav-link(href="#pricing") BẢNG GIÁ
            if sections.services
              a.tour-nav-link(href="#services") DỊCH VỤ
            if sections.notes
              a.tour-nav-link(href="#notes") LƯU Ý
            a.tour-nav-link(href="#reviews") ĐÁNH GIÁ

        // Content Sections - Continuous Scroll Layout
        .tour-content-sections

          // Section: Overview
          if sections.overview
            section.tour-section#overview(data-aos="fade-up" data-aos-delay=sectionAosDelay)
              - sectionAosDelay += 80
              - const overviewHtml = cleanHtml(sections.overview)
              - const overviewHasHeading = /^\s*<h[2-4]\b/i.test(overviewHtml)
              .tour-overview!= overviewHasHeading ? overviewHtml : `<h3>GIỚI THIỆU</h3>${overviewHtml}`

          // Section: Highlights
          if sections.highlights
            section.tour-section#highlights(data-aos="fade-up" data-aos-delay=sectionAosDelay)
              - sectionAosDelay += 80
              - const highlightsHtml = cleanHtml(sections.highlights)
              - const highlightsHasHeading = /^\s*<h[2-4]\b/i.test(highlightsHtml)
              .tour-highlights!= highlightsHasHeading ? highlightsHtml : `<h3>ĐIỂM NỔI BẬT</h3>${highlightsHtml}`

          // Section: Itinerary
          if sections.itinerary
            section.tour-section#itinerary(data-aos="fade-up" data-aos-delay=sectionAosDelay)
              - sectionAosDelay += 80
              - const rawItineraryHtml = cleanHtml(sections.itinerary)
              - let itineraryHtml = rawItineraryHtml
              - const itineraryHasHeading = /^\s*<h[2-4]\b/i.test(rawItineraryHtml)
              - if (!itineraryHasHeading) itineraryHtml = `<h3>LỊCH TRÌNH</h3>${rawItineraryHtml}`
              - const trimmedItinerary = itineraryHtml.trim()
              - const lowerItinerary = trimmedItinerary.toLowerCase()
              - if (lowerItinerary.startsWith('<h3')) {
              -   const firstCloseIndex = lowerItinerary.indexOf('</h3>')
              -   if (firstCloseIndex !== -1) {
              -     const head = trimmedItinerary.slice(0, firstCloseIndex + 5)
              -     let tail = trimmedItinerary.slice(firstCloseIndex + 5)
              -     tail = tail.replace(/<h3(\b[^>]*)>/gi, '<h4$1>').replace(/<\/h3>/gi, '</h4>')
              -     itineraryHtml = head + tail
              -   }
              - }
              .tour-itinerary!= itineraryHtml

          // Section: Pricing
          if schedules.length
            section.tour-section#pricing(data-aos="fade-up" data-aos-delay=sectionAosDelay)
              - sectionAosDelay += 80
              h3.tour-section__title BẢNG GIÁ
              .tour-pricing-table
                table.schedule-table.schedule-table--expandable
                  thead
                    tr
                      th STT
                      th Ngày khởi hành
                      th Số chỗ còn
                      th Giá từ
                      th Đặc điểm
                      th Hành động
                  tbody
                    each s, index in schedules
                      // Main row
                      tr.schedule-row(data-schedule-id=s.id)
                        td
                          button.schedule-toggle(type="button" onclick=`toggleScheduleDetail('${s.id}')`)
                            span.schedule-toggle__icon.schedule-toggle__icon--plus(id=`icon-plus-${s.id}`)
                              +fa('plus')
                            span.schedule-toggle__icon.schedule-toggle__icon--minus.hidden(id=`icon-minus-${s.id}`)
                              +fa('minus')
                          span.schedule-number= index + 1
                        td
                          strong.icon-text
                            +fa('calendar')
                            | #{formatDate(s.start_date)}
                        td
                          if s.available_slots > 0
                            span.text-success= s.available_slots
                          else
                            span.text-danger Hết chỗ
                        td= formatPrice(tour.price_adult)
                        td
                          button.schedule-eye-toggle(type="button" onclick=`togglePriceDetail('${s.id}')` title="Xem chi tiết giá")
                            i.fa-regular.fa-eye.schedule-eye(id=`eye-${s.id}`)
                            i.fa-regular.fa-eye-slash.schedule-eye-slash.hidden(id=`eye-slash-${s.id}`)
                        td
                          if s.available_slots > 0
                            if canBookTour
                              a.btn.btn--primary.btn--sm(href=`/booking/${s.id}`) Chọn
                            else
                              button.btn.btn--outline.btn--sm(type="button" disabled title=bookingRestrictedMessage) Chọn
                          else
                            button.btn.btn--outline.btn--sm(disabled) Đã đầy
                      // Expandable price detail row
                      tr.schedule-detail-row.hidden(id=`detail-${s.id}`)
                        td(colspan="6")
                          .schedule-price-detail
                            table.price-detail-table
                              thead
                                tr
                                  th Loại giá/Độ tuổi
                                  th Người lớn (>13 tuổi)
                                  th Trẻ em (<13 tuổi)
                              tbody
                                tr
                                  td Giá
                                  td= formatPrice(tour.price_adult)
                                  td= formatPrice(tour.price_child)
                                tr
                                  td Phụ thu
                                  td 0₫
                                  td 0₫
                                tr
                                  td Giảm giá
                                  td 0₫
                                  td 0₫

          // Section: Services
          if sections.services
            section.tour-section#services(data-aos="fade-up" data-aos-delay=sectionAosDelay)
              - sectionAosDelay += 80
              - const servicesHtml = cleanHtml(sections.services)
              - const servicesHasHeading = /^\s*<h[2-4]\b/i.test(servicesHtml)
              .tour-services!= servicesHasHeading ? servicesHtml : `<h3>DỊCH VỤ</h3>${servicesHtml}`

          // Section: Notes
          if sections.notes
            section.tour-section#notes(data-aos="fade-up" data-aos-delay=sectionAosDelay)
              - sectionAosDelay += 80
              - const notesHtml = cleanHtml(sections.notes)
              - const notesHasHeading = /^\s*<h[2-4]\b/i.test(notesHtml)
              .tour-notes!= notesHasHeading ? notesHtml : `<h3>LƯU Ý</h3>${notesHtml}`

        //- ── Section Reviews ──────────────────────
        section#reviews.reviews-section(data-aos="fade-up" data-aos-delay=sectionAosDelay)

          .reviews-header(data-aos="fade-up" data-aos-delay="40")
            h2 Đánh giá từ khách hàng
            if ratingInfo && ratingInfo.total > 0
              .rating-summary
                span.rating-summary__score= ratingInfo.avg_rating
                span.rating-summary__stars!= renderStars(ratingInfo.avg_rating)
                span.rating-summary__count (#{ratingInfo.total} đánh giá)

          //- Form gửi đánh giá
          if user
            if canReview && !hasReviewed
              .review-form-wrap(data-aos="fade-up" data-aos-delay="80")
                h3 Viết đánh giá của bạn
                form.review-form(action="/reviews" method="POST")
                  input(type="hidden" name="tour_id" value=tour.id)
                  input(type="hidden" name="_csrf" value=csrfToken)
                  .star-picker
                    label Chọn số sao
                    .stars-input
                      - for(let i = 5; i >= 1; i--)
                        input(type="radio" name="rating" id=`star${i}` value=`${i}` required)
                        label(for=`star${i}` title=`${i} sao`)
                          +fa('star')

                  .form-group
                    label Nhận xét
                    textarea.form-control(
                      name="comment" rows="3"
                      minlength="10" maxlength="1000" required
                      placeholder="Chia sẻ trải nghiệm của bạn (tối thiểu 10 ký tự, tối đa 1000 ký tự)..."
                    )
                  button.btn.btn--primary(type="submit") Gửi đánh giá

            else if hasReviewed
              .review-notice.review-notice--done(data-aos="fade-up" data-aos-delay="80")
                +fa('check')
                |  Bạn đã đánh giá tour này rồi

            else
              .review-notice(data-aos="fade-up" data-aos-delay="80") Bạn cần hoàn thành tour để có thể đánh giá
          else
            .review-notice(data-aos="fade-up" data-aos-delay="80")
              a(href="/login") Đăng nhập
              |  để gửi đánh giá

          //- Danh sách reviews
          if !reviews || reviews.length === 0
            p.no-reviews#noReviews(data-aos="fade-up" data-aos-delay="80") Chưa có đánh giá nào. Hãy là người đầu tiên!
          else
            .review-list#reviewsList
              each rv, idx in reviews
                .review-item(data-aos="fade-up" data-aos-delay=String(80 + (idx % 6) * 60))
                  .review-item__avatar= (rv.user_name || 'K').trim().charAt(0).toUpperCase()
                  .review-item__content
                    .review-item__header
                      span.review-item__author= rv.user_name
                      span.review-item__stars!= renderStars(rv.rating)
                      span.review-item__date= formatDate(rv.created_at)
                    if rv.comment
                      p.review-item__comment= rv.comment

            if reviewTotalPages > 1
              .pagination.reviews-pagination#reviewsPagination(data-aos="fade-up" data-aos-delay="120")
                - const reviewBase = `/tours/${tour.slug}?review_page=`
                if reviewPage > 1
                  a.pagination__item(href=`${reviewBase}${reviewPage - 1}#reviews`)
                    +fa('chevron-left')
                    |  Trước
                each p in Array.from({length: reviewTotalPages}, (_, i) => i + 1)
                  a(
                    href=`${reviewBase}${p}#reviews`
                    class=`pagination__item${p === reviewPage ? ' active' : ''}`
                  )= p
                if reviewPage < reviewTotalPages
                  a.pagination__item(href=`${reviewBase}${reviewPage + 1}#reviews`)
                    | Tiếp 
                    +fa('chevron-right')

      aside.tour-booking-box
        if schedules.length === 0
          h3.booking-box__title Lịch trình khởi hành
          p.booking-box__empty Hiện chưa có lịch trình khả dụng.
          a.btn.btn--outline.btn--block.btn--check(href="/tours") Xem tour khác
        else
          - const nearestSchedule = schedules[0]
          - const upcomingDates = schedules.slice(0, 4)

          .booking-box__price-header
            span.label Giá chỉ từ
            .price= formatPrice(tour.price_adult)

          .booking-box__summary
            .summary-item
              span.icon-text
                +fa('calendar')
                |  Ngày đi: 
              strong
                each s, index in upcomingDates
                  span #{formatDate(s.start_date).substring(0, 5)}
                  if index < upcomingDates.length - 1
                    | , 
                if schedules.length > 4
                  | ...
            .summary-item
              span.icon-text
                +fa('location')
                |  Điểm khởi hành: 
              strong #{nearestSchedule.departure_location}
            .summary-item
              span.icon-text
                +fa('user')
                |  Số chỗ còn nhận (gần nhất): 
              strong.text-danger #{nearestSchedule.available_slots} chỗ

          button.btn.btn--danger.btn--block.btn--outline(type="button" onclick="openScheduleModal()") 
            | XEM LỊCH ĐI CÁC NGÀY KHÁC
          
          if canBookTour
            a.btn.btn--primary.btn--block.btn--book-cta(href=`/booking/${nearestSchedule.id}`)
              strong ĐẶT GIỮ CHỖ NGAY
              small Đặt ngay ngày #{formatDate(nearestSchedule.start_date)}
          else
            button.btn.btn--outline.btn--block.btn--book-cta(type="button" disabled title=bookingRestrictedMessage)
              strong KHÔNG THỂ ĐẶT TOUR
              small Dùng tài khoản khách hàng để đặt tour

  .mobile-booking-bar
    if schedules.length === 0
      .mobile-booking-bar__price
        span Lịch trình
        strong Chưa có ngày đi
      a.btn.btn--outline.btn--sm.btn--out(href="/tours") Xem tour khác
    else
      - const mobileSchedule = schedules[0]
      .mobile-booking-bar__price
        span Giá từ
        strong= formatPrice(tour.price_adult)
        small #{formatDate(mobileSchedule.start_date)} · #{mobileSchedule.available_slots} chỗ
      .mobile-booking-bar__actions
        button.btn.btn--outline.btn--sm(type="button" onclick="openScheduleModal()") Lịch đi
        if mobileSchedule.available_slots > 0
          if canBookTour
            a.btn.btn--primary.btn--sm(href=`/booking/${mobileSchedule.id}`) Đặt ngay
          else
            button.btn.btn--outline.btn--sm(type="button" disabled title=bookingRestrictedMessage) Đặt ngay
        else
          button.btn.btn--outline.btn--sm(type="button" disabled) Đã đầy

  #scheduleModal.modal
    .modal-content
      .modal-header
        h3 Danh sách lịch trình khởi hành
        button.modal-close(onclick="closeScheduleModal()")
          +fa('xmark')
      .modal-body
        table.schedule-table
          thead
            tr
              th STT
              th Ngày khởi hành
              th Ngày kết thúc
              th Điểm khởi hành
              th Số chỗ còn
              th Giá người lớn
              th Hành động
          tbody
            each s, index in schedules
              tr
                td= index + 1
                td
                  strong.icon-text
                    +fa('calendar')
                    | #{formatDate(s.start_date)}
                td 
                  strong #{formatDate(s.end_date)}
                td #{s.departure_location}
                td
                  if s.available_slots > 0
                    span.text-success= s.available_slots
                  else
                    span.text-danger Hết chỗ
                td= formatPrice(tour.price_adult)
                td
                  if s.available_slots > 0
                    if canBookTour
                      a.btn.btn--primary.btn--sm(href=`/booking/${s.id}`) Chọn
                    else
                      button.btn.btn--outline.btn--sm(type="button" disabled title=bookingRestrictedMessage) Chọn
                  else
                    button.btn.btn--outline.btn--sm(disabled) Đã đầy

block scripts
  script(src="/assets/js/tour-gallery.js")
  script.
    const scheduleModal = document.getElementById('scheduleModal');

    function openScheduleModal() {
      document.getElementById('scheduleModal').classList.add('show');
      document.body.style.overflow = 'hidden'; 
    }
    function closeScheduleModal() {
      document.getElementById('scheduleModal').classList.remove('show');
      document.body.style.overflow = 'auto';
    }
    window.onclick = function(event) {
      const modal = document.getElementById('scheduleModal');
      if (event.target == modal) {
        closeScheduleModal();
      }
    }

    // Tour navigation active state
    document.addEventListener('DOMContentLoaded', function() {
      window.applyGlobalAOS?.();
      const navLinks = document.querySelectorAll('.tour-nav-link');
      
      // Set active on click
      navLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          navLinks.forEach(l => l.classList.remove('active'));
          this.classList.add('active');
        });
      });

      // Set active on scroll
      const sections = document.querySelectorAll('.tour-section, #reviews');
      
      window.addEventListener('scroll', function() {
        let current = '';
        sections.forEach(section => {
          const sectionTop = section.offsetTop - 200;
          if (window.pageYOffset >= sectionTop) {
            current = section.getAttribute('id');
          }
        });

        if (current) {
          navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${current}`) {
              link.classList.add('active');
            }
          });
        }
      });

      // Set initial active based on URL hash
      const hash = window.location.hash;
      if (hash) {
        navLinks.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('href') === hash) {
            link.classList.add('active');
          }
        });
      } else {
        // Set first link as active by default
        if (navLinks.length > 0) {
          navLinks[0].classList.add('active');
        }
      }
    });
