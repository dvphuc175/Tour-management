nav.navbar
  .navbar__inner
    .navbar__brand
      a(href="/").navbar__logo Vi Vu Việt Nam

    button.navbar__toggle(
      type="button"
      aria-label="Mở menu"
      aria-expanded="false"
      aria-controls="navbar-panel"
    )
      span.navbar__toggle-bar
      span.navbar__toggle-bar
      span.navbar__toggle-bar

    #navbar-panel.navbar__panel
      .navbar__menu
        a(href="/" class=currentPath === '/' ? 'navbar__link--active' : '') Trang chủ
        a(href="/about" class=currentPath === '/about' ? 'navbar__link--active' : '') Giới thiệu
        a(href="/tours" class=(currentPath && currentPath.startsWith('/tours')) ? 'navbar__link--active' : '') Khám phá tour
        a(href="/contact" class=currentPath === '/contact' ? 'navbar__link--active' : '') Liên hệ

      .navbar__auth
        if user
          .navbar__dropdown
            button.navbar__dropdown-toggle(type="button" aria-haspopup="true" aria-expanded="false")
              +fa('user')
              |  Xin chào, #{user.fullname}
            .navbar__dropdown-menu
              a.navbar__dropdown-item(href="/profile")
                +fa('user-circle')
                |  Thông tin tài khoản
              a.navbar__dropdown-item(href="/my-bookings")
                +fa('ticket')
                |  Đơn của tôi
              if user.role === 'admin'
                a.navbar__dropdown-item(href="/admin")
                  +fa('gear')
                  |  Quản trị
              .navbar__dropdown-divider
              form.form--inline(action="/logout?_method=DELETE" method="POST")
                input(type="hidden" name="_csrf" value=csrfToken)
                button.navbar__dropdown-item(type="submit")
                  +fa('right-from-bracket')
                  |  Đăng xuất
        else
          a.navbar__link(href="/login") Đăng nhập
          a.btn.btn--primary.btn--sm(href="/register") Đăng ký

    