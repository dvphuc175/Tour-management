include mixins/icons

doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title ? `${title} | Vi Vu Việt Nam` : 'Tour Du Lịch Việt Nam'
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css")
    link(rel="stylesheet" href="/assets/css/main.css")
    block head

  body
    include partials/navbar

    if success && success.length
      .flash.flash--success
        each msg in success
          .flash__item
            .flash__icon
              i.fas.fa-check-circle
            .flash__content= msg
            button.flash__close(type="button" aria-label="Đóng")
              i.fas.fa-times
    if error && error.length
      .flash.flash--error
        each msg in error
          .flash__item
            .flash__icon
              i.fas.fa-exclamation-circle
            .flash__content= msg
            button.flash__close(type="button" aria-label="Đóng")
              i.fas.fa-times

    main.main-content
      block content

    //- ── Footer ─────────────────────────────────
    footer.footer#contact
      .container
        .footer__content
          .footer__col
            h3.footer__title Vi Vu Việt Nam
            p.footer__desc Công ty chuyên cung cấp các tour du lịch chất lượng cao khắp Việt Nam. Trải nghiệm du lịch tuyệt vời cùng chúng tôi!
            .footer__social
              a.footer__social-link(href="#" aria-label="Facebook")
                +fa('facebook')
              a.footer__social-link(href="#" aria-label="Instagram")
                +fa('instagram')
              a.footer__social-link(href="#" aria-label="Zalo")
                img(src="/assets/images/Zalo.jpg" alt="Zalo")
          .footer__col
            h3.footer__title Liên kết nhanh
            a.footer__link(href="/") Trang chủ
            a.footer__link(href="/tours") Khám phá tour
            a.footer__link(href="/my-bookings") Đơn của tôi
          .footer__col
            h3.footer__title Liên hệ
            .footer__contact
              .footer__contact-item
                +fa('location-dot')
                span 123 Đường ABC, Quận 1, TP. Hồ Chí Minh
              .footer__contact-item
                +fa('phone')
                span 0345.043.213
              .footer__contact-item
                +fa('envelope')
                span info@vivuvietnam.com
              .footer__contact-item
                +fa('clock')
                span 8:00 - 22:00 mỗi ngày
        .footer__bottom
          p &copy; 2024 Vi Vu Việt Nam. All rights reserved.

    #zalo-widget
      #zalo-button(onclick="toggleZaloChat()")
        img(src="/assets/images/Zalo.jpg" alt="Chat Zalo")

      #zalo-chat-window
        .zalo-header
          img(src="/assets/images/Zalo.jpg" alt="Zalo")
          div
            .zalo-header__title Vi Vu Việt Nam
            .zalo-header__sub Hỗ trợ 24/7
          span.zalo-header__close(onclick="toggleZaloChat()")
            +fa('xmark')

        .zalo-body
          p
            +fa('hand')
            |  Xin chào!
            br
            | Chúng tôi có thể giúp gì cho bạn?
          a.zalo-body__cta(href="https://zalo.me/0345043213" target="_blank")
            +fa('comment')
            |  Chat ngay trên Zalo

    script(src="/assets/js/main.js")
    block scripts

    script.
      function toggleZaloChat() {
        document.getElementById('zalo-chat-window').classList.toggle('is-open');
      }

      document.addEventListener('click', function(e) {
        const widget = document.getElementById('zalo-widget');
        const chatWindow = document.getElementById('zalo-chat-window');
        if (chatWindow.classList.contains('is-open') && !widget.contains(e.target)) {
          chatWindow.classList.remove('is-open');
        }
      });
