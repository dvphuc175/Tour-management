doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title ? `${title} | Vi Vu Việt Nam` : 'Tour Du Lịch Việt Nam'
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600&family=Sora:wght@600;700&display=swap")
    link(rel="stylesheet" href="/assets/css/main.css")
    block head

  body
    include partials/navbar

    //- Flash messages
    if success && success.length
      .flash.flash--success
        each msg in success
          p= msg
    if error && error.length
      .flash.flash--error
        each msg in error
          p= msg

    main.container
      block content

    //- include partials/footer (Sẽ làm sau)
    script(src="/assets/js/main.js")
    block scripts