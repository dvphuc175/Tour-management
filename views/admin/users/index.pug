extends ../layout
include ../_pagination

block content
  .toolbar
    form.filter-form.filter-form--inline(method="GET" action="/admin/users")
      input.form-control.form-control--sm.filter-search(
        type="search"
        name="q"
        placeholder="Tìm tên, email, SĐT"
        value=filters.q
      )
      select.form-control.form-control--sm(name="role" onchange="this.form.submit()")
        option(value="" selected=!filters.role) Tất cả vai trò
        option(value="admin" selected=filters.role==='admin') Admin
        option(value="staff" selected=filters.role==='staff') Nhân viên
        option(value="customer" selected=filters.role==='customer') Khách hàng
      select.form-control.form-control--sm(name="status" onchange="this.form.submit()")
        option(value="" selected=!filters.status) Tất cả trạng thái
        option(value="active" selected=filters.status==='active') Hoạt động
        option(value="locked" selected=filters.status==='locked') Đã khóa
      button.btn.btn--primary.btn--sm(type="submit")
        +fa('search')
        |  Lọc
      if hasFilters
        a.btn.btn--outline.btn--sm(href="/admin/users")
          +fa('rotate')
          |  Xóa lọc

  .table-wrap
    table.data-table.data-table--users
      thead
        tr
          th ID
          th Họ tên
          th Email
          th SĐT
          th Vai trò
          th Trạng thái
          th Ngày đăng ký
          th Thao tác
      tbody
        if users.length === 0
          tr
            td.table-empty(colspan="8")= hasFilters ? 'Không tìm thấy người dùng phù hợp' : 'Chưa có người dùng nào'
        each u in users
          - var isSelf = user && user.id === u.id
          tr(class=u.status === 'locked' ? 'row--locked' : '')
            td= u.id
            td
              strong.cell-truncate.cell-md(title=u.fullname)= u.fullname
            td
              span.cell-truncate.cell-lg(title=u.email)= u.email
            td
              span.cell-truncate.cell-sm(title=u.phone || '')= u.phone || '—'
            td
              - var roleBadge = u.role === 'admin' ? 'badge--confirmed' : (u.role === 'staff' ? 'badge--pending' : 'badge--active')
              - var roleLabel = u.role === 'admin' ? 'Admin' : (u.role === 'staff' ? 'Nhân viên' : 'Khách hàng')
              span(class=`badge ${roleBadge}`)= roleLabel
            td
              span(class=`badge badge--${u.status}`)
                = u.status === 'active' ? 'Hoạt động' : 'Đã khóa'
            td= formatDate(u.created_at)
            td
              .user-actions
                //- Đổi role: không cho phép đổi role của chính mình
                if isSelf
                  span.text-muted (tài khoản hiện tại)
                else
                  form.role-form(
                    action=`/admin/users/${u.id}/role?_method=PUT`
                    method="POST"
                    data-confirm=`Đổi vai trò của ${u.fullname}?`
                  )
                    input(type="hidden" name="_csrf" value=csrfToken)
                    input(type="hidden" name="returnTo" value=returnTo)
                    select(name="role" class="form-control form-control--sm form-control--compact")
                      option(value="customer" selected=(u.role==='customer')) Khách hàng
                      option(value="staff" selected=(u.role==='staff')) Nhân viên
                      option(value="admin" selected=(u.role==='admin')) Admin
                    button(type="submit" class="btn btn--sm btn--outline") Đổi
                  if u.role !== 'admin'
                    form(
                      action=`/admin/users/${u.id}/toggle-status?_method=PUT`
                      method="POST"
                      data-confirm=u.status==='active' ? `Khóa tài khoản ${u.fullname}?` : `Mở khóa tài khoản ${u.fullname}?`
                    )
                      input(type="hidden" name="_csrf" value=csrfToken)
                      input(type="hidden" name="returnTo" value=returnTo)
                      button(
                        type="submit"
                        class=`btn btn--sm ${u.status === 'active' ? 'btn--danger' : 'btn--success'}`
                      )= u.status === 'active' ? 'Khóa' : 'Mở khóa'

  +pagination(currentPage, totalPages, paginationBaseUrl)
