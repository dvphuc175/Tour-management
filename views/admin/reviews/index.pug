extends ../layout

block content
  .table-wrap
    table.data-table
      thead
        tr
          th Tour
          th Khách hàng
          th Sao
          th Nhận xét
          th Ngày
          th Xóa
      tbody
        if reviews.length === 0
          tr
            td(colspan="6" style="text-align:center;padding:32px;color:#9ca3af") Chưa có đánh giá nào
        each rv in reviews
          tr
            td= rv.tour_name
            td= rv.user_name
            td.stars-display= '★'.repeat(rv.rating) + '☆'.repeat(5 - rv.rating)
            td.review-comment= rv.comment || '—'
            td= formatDate(rv.created_at)
            td
              form(
                action=`/admin/reviews/${rv.id}?_method=DELETE`
                method="POST"
                data-confirm="Xóa đánh giá này?"
                style="display:inline"
              )
                button.btn.btn--danger.btn--sm(type="submit") Xóa
