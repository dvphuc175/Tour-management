extends ../layout
include ../_pagination

block content
  .table-wrap
    table.data-table
      thead
        tr
          th Tour
          th Khách hàng
          th Sao
          th Nhận xét
          th Ngày
          th Xóa
      tbody
        if reviews.length === 0
          tr
            td.table-empty(colspan="6") Chưa có đánh giá nào
        each rv in reviews
          tr
            td= rv.tour_name
            td= rv.user_name
            td.stars-display!= renderStarRating(rv.rating)
            td.review-comment= rv.comment || '—'
            td= formatDate(rv.created_at)
            td
              form.form--inline(
                action=`/admin/reviews/${rv.id}?_method=DELETE`
                method="POST"
                data-confirm="Xóa đánh giá này?"
              )
                input(type="hidden" name="_csrf" value=csrfToken)
                button.btn.btn--danger.btn--sm(type="submit") Xóa

  +pagination(currentPage, totalPages, '/admin/reviews')
