extends ../layout
include ../_pagination

block content
  .toolbar
    form.filter-form.filter-form--inline(method="GET" action="/admin/reviews")
      input.form-control.form-control--sm.filter-search(
        type="search"
        name="q"
        placeholder="Tìm tour, khách hàng, nhận xét"
        value=filters.q
      )
      select.form-control.form-control--sm(name="rating" onchange="this.form.submit()")
        option(value="" selected=!filters.rating) Tất cả số sao
        option(value="5" selected=filters.rating==='5') 5 sao
        option(value="4" selected=filters.rating==='4') 4 sao
        option(value="3" selected=filters.rating==='3') 3 sao
        option(value="2" selected=filters.rating==='2') 2 sao
        option(value="1" selected=filters.rating==='1') 1 sao
      button.btn.btn--primary.btn--sm(type="submit")
        +fa('search')
        |  Lọc
      if hasFilters
        a.btn.btn--outline.btn--sm(href="/admin/reviews")
          +fa('rotate')
          |  Xóa lọc

  .table-wrap
    table.data-table.data-table--reviews
      thead
        tr
          th Tour
          th Khách hàng
          th Sao
          th Nhận xét
          th Ngày
          th Xóa
      tbody
        if reviews.length === 0
          tr
            td.table-empty(colspan="6")= hasFilters ? 'Không tìm thấy đánh giá phù hợp' : 'Chưa có đánh giá nào'
        each rv in reviews
          tr
            td
              span.cell-truncate.cell-xl(title=rv.tour_name)= rv.tour_name
            td
              span.cell-truncate.cell-md(title=rv.user_name)= rv.user_name
            td.stars-display!= renderStarRating(rv.rating)
            td.review-comment(title=rv.comment || '')
              span.cell-clamp-2.cell-xl= rv.comment || '—'
            td= formatDate(rv.created_at)
            td
              form.form--inline(
                action=`/admin/reviews/${rv.id}?_method=DELETE`
                method="POST"
                data-confirm="Xóa đánh giá này?"
              )
                input(type="hidden" name="_csrf" value=csrfToken)
                button.btn.btn--danger.btn--sm(type="submit") Xóa

  +pagination(currentPage, totalPages, paginationBaseUrl)
