extends ../../admin/layout

block content
  .page-actions
    a.btn.btn--primary(href="/admin/categories/create") + Thêm danh mục

  .table-wrap
    table.data-table
      thead
        tr
          th #
          th Tên danh mục
          th Slug
          th Mô tả
          th Trạng thái
          th Thao tác
      tbody
        if categories.length === 0
          tr
            td.table-empty(colspan="6") Chưa có danh mục nào
        each cat, i in categories
          tr
            td= i + 1
            td: strong= cat.name
            td: code= cat.slug
            td= cat.description || '—'
            td
              span(class=`badge badge--${cat.status}`)
                = cat.status === 'active' ? 'Hiển thị' : 'Ẩn'
            td.action-btns
              a.btn.btn--edit.btn--sm(href=`/admin/categories/${cat.id}/edit`) Sửa
              form.form--inline(
                action=`/admin/categories/${cat.id}?_method=DELETE`
                method="POST"
                data-confirm="Xóa danh mục này?"
              )
                input(type="hidden" name="_csrf" value=csrfToken)
                button.btn.btn--delete.btn--sm(type="submit") Xóa
  if totalPages > 1
    .pagination.pagination--admin
      
      if currentPage > 1
        a.btn.btn--outline.btn--sm(href=`/admin/categories?page=${currentPage - 1}`)
          +fa('chevron-left')
          |  Trở lại
        
      - for (let i = 1; i <= totalPages; i++)
        a.btn.btn--sm(href=`/admin/categories?page=${i}` class=(currentPage === i ? 'btn--primary' : 'btn--outline'))= i
        
      if currentPage < totalPages
        a.btn.btn--outline.btn--sm(href=`/admin/categories?page=${currentPage + 1}`)
          | Tiếp 
          +fa('chevron-right')