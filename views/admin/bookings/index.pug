extends ../../admin/layout
include ../_pagination

block content
  .toolbar
    form.filter-form.filter-form--inline(method="GET" action="/admin/bookings")
      input.form-control.form-control--sm.filter-search(
        type="search"
        name="q"
        placeholder="Tìm mã đơn, khách hàng, tour"
        value=filters.q
      )
      select.form-control.form-control--sm(name="status" onchange="this.form.submit()")
        option(value="" selected=!filters.status) Tất cả trạng thái
        option(value="pending" selected=filters.status==='pending') Chờ xác nhận
        option(value="confirmed" selected=filters.status==='confirmed') Đã xác nhận
        option(value="cancelled" selected=filters.status==='cancelled') Đã hủy
        option(value="completed" selected=filters.status==='completed') Hoàn thành
      select.form-control.form-control--sm(name="payment" onchange="this.form.submit()")
        option(value="" selected=!filters.payment) Tất cả thanh toán
        option(value="pending" selected=filters.payment==='pending') Chưa thanh toán
        option(value="success" selected=filters.payment==='success') Đã thanh toán
        option(value="failed" selected=filters.payment==='failed') Thất bại
        option(value="refunded" selected=filters.payment==='refunded') Đã hoàn tiền
      select.form-control.form-control--sm(name="method" onchange="this.form.submit()")
        option(value="" selected=!filters.method) Tất cả phương thức
        option(value="vnpay" selected=filters.method==='vnpay') VNPay
        option(value="cash" selected=filters.method==='cash') Tiền mặt
      button.btn.btn--primary.btn--sm(type="submit")
        +fa('search')
        |  Lọc
      if hasFilters
        a.btn.btn--outline.btn--sm(href="/admin/bookings")
          +fa('rotate')
          |  Xóa lọc

  .table-wrap
    table.data-table.data-table--bookings
      thead
        tr
          th #
          th Khách hàng
          th Tour
          th Ngày đi
          th Tổng tiền
          th Thanh toán
          th(title="Phương thức thanh toán") PTTT
          th Trạng thái
          th Thao tác
      tbody
        if bookings.length === 0
          tr
            td.table-empty(colspan="9")= hasFilters ? 'Không tìm thấy đơn phù hợp' : 'Không có đơn nào'
        each b in bookings
          tr
            td= b.id
            td
              .cell-stack.cell-md
                span.cell-truncate(title=b.user_name)= b.user_name
                small.cell-truncate.cell-muted(title=b.user_email)= b.user_email
            td
              span.cell-truncate.cell-xl(title=b.tour_name)= b.tour_name
            td= formatDate(b.start_date)
            td= formatPrice(b.total_price)
            //- td
            //-   span(class=bookingStatus.paymentBadgeClass(b.payment_status))
            //-     = bookingStatus.paymentStatusLabel(b.payment_status)
            //- td= bookingStatus.paymentMethodLabel(b.payment_method)
            //- td
            //-   span(class=bookingStatus.bookingBadgeClass(b.status))
            //-     = bookingStatus.bookingStatusLabel(b.status)
            //- td
            //-   a.btn.btn--outline.btn--sm(href=`/admin/bookings/${b.id}`) Chi tiết
            td
              span(class=`badge badge--${b.payment_status}`)
                = {pending:'Chưa thanh toán',success:'Đã thanh toán',failed:'Thất bại',refunded:'Đã hoàn tiền'}[b.payment_status]
            td= {vnpay:'VNPay',cash:'Tiền mặt'}[b.payment_method]
            td
              span(class=`badge badge--${b.status}`)
                = {pending:'Chờ xác nhận',confirmed:'Xác nhận',cancelled:'Đã hủy',completed:'Hoàn thành'}[b.status]
            td
              a.btn.btn--view.btn--sm(href=`/admin/bookings/${b.id}`) Chi tiết

  +pagination(currentPage, totalPages, paginationBaseUrl)
