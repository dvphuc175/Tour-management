extends ../../admin/layout

block content
  .booking-detail-admin

    //- ── Hero header with gradient background ──
    .booking-detail-hero
      .booking-detail-hero__content
        .booking-detail-hero__left
          .booking-detail-hero__id
            i.fas.fa-hashtag
            span= booking.id
          h2.booking-detail-hero__title= booking.tour_name
        .booking-detail-hero__right
          span(class=`booking-status-pill booking-status-pill--${booking.status}`)
            if booking.status === 'pending'
              i.fas.fa-clock
            else if booking.status === 'confirmed'
              i.fas.fa-check-circle
            else if booking.status === 'cancelled'
              i.fas.fa-times-circle
            else if booking.status === 'completed'
              i.fas.fa-flag-checkered
            = ' '
            = {pending:'Chờ xác nhận',confirmed:'Đã xác nhận',cancelled:'Đã hủy',completed:'Hoàn thành'}[booking.status]

    //- ── Info cards grid ──
    .booking-detail-cards

      //- Card 1: Khách hàng
      .booking-info-card.booking-info-card--customer
        .booking-info-card__header
          .booking-info-card__icon
            i.fas.fa-user
          h3.booking-info-card__title Thông tin khách hàng
        .booking-info-card__body
          .info-group
            .info-group__label
              i.fas.fa-id-badge
              span Tài khoản
            .info-group__value= booking.user_name
          .info-group
            .info-group__label
              i.fas.fa-envelope
              span Email
            .info-group__value= booking.user_email
          .info-group
            .info-group__label
              i.fas.fa-phone
              span SĐT tài khoản
            .info-group__value= booking.user_phone || '—'
          .booking-info-card__divider
          .info-group
            .info-group__label
              i.fas.fa-address-book
              span Người liên hệ
            .info-group__value= booking.contact_name
          .info-group
            .info-group__label
              i.fas.fa-mobile-alt
              span SĐT liên hệ
            .info-group__value= booking.contact_phone
          .info-group
            .info-group__label
              i.fas.fa-at
              span Email liên hệ
            .info-group__value= booking.contact_email
          if booking.special_request
            .info-group.info-group--highlight
              .info-group__label
                i.fas.fa-comment-dots
                span Yêu cầu đặc biệt
              .info-group__value.info-group__value--note= booking.special_request

      //- Card 2: Thông tin tour
      .booking-info-card.booking-info-card--tour
        .booking-info-card__header
          .booking-info-card__icon
            i.fas.fa-map-marked-alt
          h3.booking-info-card__title Thông tin tour
        .booking-info-card__body
          .info-group
            .info-group__label
              i.fas.fa-route
              span Tour
            .info-group__value
              a.info-link(href=`/tours/${booking.tour_slug}` target="_blank")
                = booking.tour_name
                i.fas.fa-external-link-alt
          .info-group
            .info-group__label
              i.fas.fa-calendar-check
              span Ngày đi
            .info-group__value= formatDate(booking.start_date)
          .info-group
            .info-group__label
              i.fas.fa-calendar-times
              span Ngày về
            .info-group__value= formatDate(booking.end_date)
          .info-group
            .info-group__label
              i.fas.fa-map-pin
              span Điểm khởi hành
            .info-group__value= booking.departure_location
          .info-group
            .info-group__label
              i.fas.fa-users
              span Hành khách
            .info-group__value
              span.passenger-tag.passenger-tag--adult
                i.fas.fa-male
                = ` ${booking.adult_count} Người lớn`
              span.passenger-tag.passenger-tag--child
                i.fas.fa-child
                = ` ${booking.child_count} Trẻ em`
          .booking-info-card__divider
          .info-group.info-group--total
            .info-group__label
              i.fas.fa-money-bill-wave
              span Tổng tiền
            .info-group__value.info-group__price= formatPrice(booking.total_price)

      //- Card 3: Thanh toán
      .booking-info-card.booking-info-card--payment
        .booking-info-card__header
          .booking-info-card__icon
            i.fas.fa-credit-card
          h3.booking-info-card__title Thanh toán
        .booking-info-card__body
          .info-group
            .info-group__label
              i.fas.fa-wallet
              span Phương thức
            .info-group__value
              span.payment-method-tag(class=booking.payment_method === 'vnpay' ? 'payment-method-tag--vnpay' : 'payment-method-tag--cash')
                if booking.payment_method === 'vnpay'
                  i.fas.fa-university
                  |  VNPay
                else
                  i.fas.fa-money-bill
                  |  Tiền mặt
          .info-group
            .info-group__label
              i.fas.fa-info-circle
              span Trạng thái
            .info-group__value
              span(class=`booking-status-pill booking-status-pill--sm booking-status-pill--${booking.payment_status}`)
                = {pending:'Chưa thanh toán',success:'Đã thanh toán',failed:'Thất bại',refunded:'Đã hoàn tiền'}[booking.payment_status]
          if booking.transaction_id
            .info-group
              .info-group__label
                i.fas.fa-receipt
                span Mã giao dịch
              .info-group__value
                code.transaction-code= booking.transaction_id
          if booking.paid_at
            .info-group
              .info-group__label
                i.fas.fa-clock
                span Thời gian TT
              .info-group__value= formatDate(booking.paid_at)

    //- ── Actions bar ──
    .booking-detail-action-bar
      a.booking-action-btn.booking-action-btn--back(href="/admin/bookings")
        i.fas.fa-arrow-left
        span Quay lại danh sách

      .booking-detail-action-bar__right
        //- Chỉ hiện "Xác nhận đơn" với đơn CASH đang pending
        if booking.status === 'pending' && booking.payment_method === 'cash'
          form.form--inline(
            action=`/admin/bookings/${booking.id}/confirm?_method=PUT`
            method="POST"
            data-confirm="Xác nhận đã nhận tiền mặt và duyệt đơn này?"
          )
            input(type="hidden" name="_csrf" value=csrfToken)
            button.booking-action-btn.booking-action-btn--confirm(type="submit")
              i.fas.fa-check-double
              span Xác nhận & Nhận tiền mặt

        //- VNPay pending: chỉ hiển thị trạng thái, không có nút duyệt
        if booking.status === 'pending' && booking.payment_method === 'vnpay'
          .booking-vnpay-waiting
            i.fas.fa-hourglass-half
            span Chờ khách thanh toán VNPay

        //- Nút "Hoàn thành tour" — cả 2 luồng, khi đã confirmed
        if booking.status === 'confirmed'
          form.form--inline(
            action=`/admin/bookings/${booking.id}/complete?_method=PUT`
            method="POST"
            data-confirm="Đánh dấu tour này đã hoàn thành?"
          )
            input(type="hidden" name="_csrf" value=csrfToken)
            button.booking-action-btn.booking-action-btn--complete(type="submit")
              i.fas.fa-flag-checkered
              span Hoàn thành tour

        //- Hủy đơn — không hủy khi đã completed
        if booking.status !== 'cancelled' && booking.status !== 'completed'
          form.form--inline(
            action=`/admin/bookings/${booking.id}/cancel?_method=PUT`
            method="POST"
            data-confirm="Hủy đơn này và hoàn lại chỗ cho lịch trình?"
          )
            input(type="hidden" name="_csrf" value=csrfToken)
            button.booking-action-btn.booking-action-btn--cancel(type="submit")
              i.fas.fa-ban
              span Hủy đơn
