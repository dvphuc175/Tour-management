extends layout

block content
  .report-filter
    form.report-filter__form(method="GET" action="/admin/reports")
      .form-group
        label(for="from") Từ ngày
        input#from(type="date" name="from" value=from)
      .form-group
        label(for="to") Đến ngày
        input#to(type="date" name="to" value=to)
      .form-group
        button.btn.btn--primary(type="submit") Lọc

  .report-summary
    .report-summary__card
      .report-summary__label Tổng doanh thu
      .report-summary__value= Number(totals.revenue || 0).toLocaleString('vi-VN') + ' ₫'
    .report-summary__card
      .report-summary__label Tổng đơn đặt
      .report-summary__value= totals.bookings || 0
    .report-summary__card
      .report-summary__label Tổng hành khách
      .report-summary__value= totals.passengers || 0

  if rows.length > 0
    .chart-card
      .chart-card__header
        h2.chart-card__title Doanh thu theo ngày
      canvas#reportChart(width="400" height="280")

    .table-wrap
      table.data-table
        thead
          tr
            th Ngày
            th Doanh thu
            th Đơn đặt
            th Hành khách
        tbody
          each row in rows
            tr
              td= row.date
              td= Number(row.revenue || 0).toLocaleString('vi-VN') + ' ₫'
              td= row.bookings || 0
              td= row.passengers || 0
  else
    .flash.flash--info
      p Không có dữ liệu trong khoảng thời gian đã chọn.

block scripts
  script(src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js")
  if rows.length > 0
    script.
      const reportData = !{chartData};
      const reportCtx = document.getElementById('reportChart');
      if (reportCtx) {
        const ctx = reportCtx.getContext('2d');
        const gradient1 = ctx.createLinearGradient(0, 0, 0, 280);
        gradient1.addColorStop(0, 'rgba(59, 130, 246, 0.45)');
        gradient1.addColorStop(1, 'rgba(59, 130, 246, 0.03)');
        
        const gradient2 = ctx.createLinearGradient(0, 0, 0, 280);
        gradient2.addColorStop(0, 'rgba(245, 158, 11, 0.45)');
        gradient2.addColorStop(1, 'rgba(245, 158, 11, 0.03)');
        
        new Chart(reportCtx, {
          type: 'line',
          data: {
            labels: reportData.labels,
            datasets: [
              {
                label: 'Doanh thu',
                data: reportData.revenue,
                borderColor: '#3b82f6',
                backgroundColor: gradient1,
                borderWidth: 3,
                tension: 0.4,
                fill: true,
                pointRadius: 5,
                pointHoverRadius: 7,
                pointBackgroundColor: '#3b82f6',
                pointBorderColor: '#fff',
                pointBorderWidth: 3
              },
              {
                label: 'Đơn đặt',
                data: reportData.bookings,
                borderColor: '#f59e0b',
                backgroundColor: gradient2,
                borderWidth: 3,
                tension: 0.4,
                fill: true,
                pointRadius: 5,
                pointHoverRadius: 7,
                pointBackgroundColor: '#f59e0b',
                pointBorderColor: '#fff',
                pointBorderWidth: 3
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: {
              duration: 1500,
              easing: 'easeOutQuart'
            },
            interaction: {
              intersect: false,
              mode: 'index'
            },
            plugins: { 
              legend: { 
                position: 'top',
                labels: {
                  usePointStyle: true,
                  padding: 20,
                  font: {
                    size: 13,
                    weight: 600
                  }
                }
              },
              tooltip: {
                backgroundColor: '#1f2937',
                padding: 12,
                titleFont: { size: 14, weight: 700 },
                bodyFont: { size: 13 },
                cornerRadius: 10,
                callbacks: {
                  label: function(context) {
                    let label = context.dataset.label || '';
                    if (label) {
                      label += ': ';
                    }
                    if (context.parsed.y !== null) {
                      label += new Intl.NumberFormat('vi-VN').format(context.parsed.y);
                    }
                    return label;
                  }
                }
              }
            },
            scales: {
              x: { 
                grid: { display: false },
                ticks: { font: { weight: 600 }, color: '#64748b' }
              },
              y: {
                grid: { color: 'rgba(226, 232, 240, 0.5)' },
                ticks: {
                  font: { weight: 600 },
                  color: '#64748b',
                  callback: value => new Intl.NumberFormat('vi-VN').format(value)
                }
              }
            }
          }
        });
      }
