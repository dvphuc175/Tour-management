mixin pagination(currentPage, totalPages, baseUrl)
  if totalPages > 1
    - var sep = baseUrl.indexOf('?') === -1 ? '?' : '&'
    .pagination(style="margin-top: 24px; display: flex; gap: 8px; justify-content: flex-end; align-items: center;")
      if currentPage > 1
        a.btn.btn--outline.btn--sm(href=`${baseUrl}${sep}page=${currentPage - 1}`) &laquo; Trở lại

      - for (let i = 1; i <= totalPages; i++)
        a.btn.btn--sm(
          href=`${baseUrl}${sep}page=${i}`
          class=(currentPage === i ? 'btn--primary' : 'btn--outline')
        )= i

      if currentPage < totalPages
        a.btn.btn--outline.btn--sm(href=`${baseUrl}${sep}page=${currentPage + 1}`) Tiếp &raquo;
