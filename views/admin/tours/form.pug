extends ../../admin/layout

block content
    .form-card.form-card--wide
        -
            const isEdit   = tour != null
            const action   = isEdit ? `/admin/tours/${tour.id}?_method=PUT` : '/admin/tours'

        form(action=action method="POST" enctype="multipart/form-data")

            .form-row
                .form-group.form-group--grow
                    label Tên tour
                    input.form-control(
                        type="text" name="name"
                        value=tour ? tour.name : ''
                        placeholder="Ví dụ: Tour Hạ Long 3N2Đ"
                        required
                    )
                .form-group
                    label Danh mục
                    select.form-control(name="category_id")
                        option(value="") -- Chọn danh mục --
                        each cat in categories
                            option(value=cat.id selected=tour && tour.category_id == cat.id)= cat.name

            .form-row
                .form-group
                    label Giá người lớn (VNĐ)
                    input.form-control(
                        type="number" name="price_adult" min="0" step="1000"
                        value=tour ? tour.price_adult : ''
                        placeholder="2500000"
                        required
                    )
                .form-group
                    label Giá trẻ em (VNĐ)
                    input.form-control(
                        type="number" name="price_child" min="0" step="1000"
                        value=tour ? tour.price_child : ''
                        placeholder="1500000"
                        required
                    )
                .form-group
                    label Trạng thái
                    select.form-control(name="status")
                        option(value="active" selected=!tour || tour.status==='active') Hiển thị
                        option(value="hidden" selected=tour && tour.status==='hidden') Ẩn

            .form-group
                label Mô tả lịch trình
                // Section Marker Toolbar
                .section-toolbar
                    span.section-toolbar__label Chèn phần:
                    button.section-btn(type="button" onclick="insertSection('overview')" title="Giới thiệu tour") 📋 Giới thiệu
                    button.section-btn(type="button" onclick="insertSection('highlights')" title="Điểm nổi bật") ⭐ Điểm nổi bật
                    button.section-btn(type="button" onclick="insertSection('itinerary')" title="Lịch trình") 🗓️ Lịch trình
                    button.section-btn(type="button" onclick="insertSection('services')" title="Dịch vụ") 🛎️ Dịch vụ
                    button.section-btn(type="button" onclick="insertSection('notes')" title="Lưu ý") 📝 Lưu ý
                textarea#description.form-control(name="description")= isEdit ? tour.description : ''
            //- Ảnh hiện tại (khi edit)
            if isEdit && tour.images && tour.images.length
                .form-group
                    label Ảnh hiện tại
                    .image-preview-grid
                        each imgUrl, idx in tour.images
                            .image-preview-item
                                img(src=imgUrl alt=`Ảnh ${idx+1}`)
                                label.img-remove-label
                                    input(
                                        type="checkbox"
                                        name="keep_images"
                                        value=imgUrl
                                        checked
                                        onchange="toggleImgKeep(this)"
                                    )
                                    span Giữ ảnh

            //- Upload ảnh mới
            .form-group
                label= isEdit ? 'Thêm ảnh mới (tối đa 10 ảnh)' : 'Ảnh tour (tối đa 10 ảnh)'
                input#imageUpload.form-control(
                    type="file" name="images"
                    accept="image/*" multiple
                )
                .upload-preview#uploadPreview

            .form-actions
                button.btn.btn--primary(type="submit")= isEdit ? 'Cập nhật tour' : 'Thêm tour'
                a.btn.btn--outline(href="/admin/tours") Hủy

block scripts
  script(src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js")
  script.
    let editorInstance;

    ClassicEditor
      .create(document.querySelector('#description'), {
        toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'undo', 'redo'],
        heading: {
          options: [
            { model: 'paragraph', title: 'Paragraph', class: 'ck-heading_paragraph' },
            { model: 'heading1', view: 'h1', title: 'Heading 1', class: 'ck-heading_heading1' },
            { model: 'heading2', view: 'h2', title: 'Heading 2', class: 'ck-heading_heading2' },
            { model: 'heading3', view: 'h3', title: 'Heading 3', class: 'ck-heading_heading3' }
          ]
        },
        htmlSupport: {
          allow: [
            { name: /.*/, attributes: true, classes: true, styles: true }
          ]
        }
      })
      .then(editor => {
        editorInstance = editor;
      })
      .catch(error => {
        console.error(error);
      });

    // Section templates - properly formatted HTML
    const sectionTemplates = {
      overview: '<!-- SECTION:overview --><h3>Giới thiệu tour</h3><p>Mô tả tổng quan về tour...</p><!-- ENDSECTION -->',
      highlights: '<!-- SECTION:highlights --><h3>Điểm nổi bật</h3><ul><li>Điểm nổi bật 1</li><li>Điểm nổi bật 2</li><li>Điểm nổi bật 3</li></ul><!-- ENDSECTION -->',
      itinerary: '<!-- SECTION:itinerary --><h3>Ngày 1:</h3><ul><li>Hoạt động sáng</li><li>Hoạt động chiều</li><li>Hoạt động tối</li></ul><!-- ENDSECTION -->',
      services: '<!-- SECTION:services --><h3>Dịch vụ bao gồm</h3><ul><li>Dịch vụ 1</li><li>Dịch vụ 2</li><li>Dịch vụ 3</li></ul><h3>Dịch vụ không bao gồm</h3><ul><li>Không bao gồm 1</li><li>Không bao gồm 2</li></ul><!-- ENDSECTION -->',
      pricing: '<!-- SECTION:pricing --><h3>Bảng giá chi tiết</h3><ul><li>Người lớn: ...</li><li>Trẻ em (5-11 tuổi): ...</li><li>Trẻ em dưới 5 tuổi: ...</li></ul><!-- ENDSECTION -->',
      notes: '<!-- SECTION:notes --><h3>Lưu ý quan trọng</h3><ul><li>Lưu ý 1</li><li>Lưu ý 2</li><li>Lưu ý 3</li></ul><!-- ENDSECTION -->'
    };

    async function insertSection(sectionName) {
      if (!editorInstance) return;

      const template = sectionTemplates[sectionName];
      if (!template) return;

      const currentData = editorInstance.getData();

      // Add paragraph after section to prevent heading continuation
      const sectionWithParagraph = template + '<p>&nbsp;</p>';

      // Append to existing content
      const separator = currentData && !currentData.endsWith('<p>&nbsp;</p>') ? '' : '';
      const newData = currentData + separator + sectionWithParagraph;

      await editorInstance.setData(newData);

      // Focus back to editor
      editorInstance.editing.view.focus();
    }

    function toggleImgKeep(checkbox) {
      const label = checkbox.closest('.img-remove-label');
      if (checkbox.checked) {
        label.classList.remove('removing');
      } else {
        label.classList.add('removing');
      }
    }
  script(src="/assets/js/upload-preview.js")