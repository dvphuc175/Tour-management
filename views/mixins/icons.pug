//- Font Awesome icon mixin
mixin fa(name, style)
  - const prefix = style === 'regular' ? 'fa-regular' : (style === 'brands' ? 'fa-brands' : 'fa-solid')
  - const icons = { calendar: 'fa-calendar-days', location: 'fa-location-dot', 'location-dot': 'fa-location-dot', user: 'fa-user', 'user-circle': 'fa-user-circle', users: 'fa-users', clock: 'fa-clock', rotate: 'fa-rotate-right', info: 'fa-circle-info', check: 'fa-check', warning: 'fa-triangle-exclamation', comment: 'fa-comment-dots', phone: 'fa-phone', 'phone-volume': 'fa-phone-volume', circle: 'fa-circle', hand: 'fa-hand', xmark: 'fa-xmark', 'chevron-left': 'fa-chevron-left', 'chevron-right': 'fa-chevron-right', 'arrow-left': 'fa-arrow-left', 'arrow-right': 'fa-arrow-right', plus: 'fa-plus', minus: 'fa-minus', eye: 'fa-eye', 'eye-slash': 'fa-eye-slash', plane: 'fa-plane', house: 'fa-house', receipt: 'fa-file-invoice', money: 'fa-sack-dollar', 'money-bill-wave': 'fa-money-bill-wave', map: 'fa-map', star: 'fa-star', chart: 'fa-chart-line', folder: 'fa-folder', filter: 'fa-filter', ticket: 'fa-ticket', 'chart-pie': 'fa-chart-pie', gear: 'fa-gear', logout: 'fa-right-from-bracket', 'right-from-bracket': 'fa-right-from-bracket', search: 'fa-magnifying-glass', times: 'fa-xmark', envelope: 'fa-envelope', 'paper-plane': 'fa-paper-plane', 'user-tie': 'fa-user-tie', compass: 'fa-compass', heart: 'fa-heart', headset: 'fa-headset', award: 'fa-award', tree: 'fa-tree', palette: 'fa-palette', 'map-location-dot': 'fa-map-location-dot', 'mountain-sun': 'fa-mountain-sun', 'landmark-dome': 'fa-landmark-dome' }
  i(class=`${prefix} ${icons[name] || name} icon` aria-hidden="true")

//- Icon + text
mixin faText(name, text, style)
  span.icon-text
    +fa(name, style)
    | #{text}