//- Font Awesome icon mixin — +fa('calendar') hoặc +fa('star', 'regular')
mixin fa(name, style)
  - const prefix = style === 'regular' ? 'fa-regular' : (style === 'brands' ? 'fa-brands' : 'fa-solid')
  - const icons = { calendar: 'fa-calendar-days', location: 'fa-location-dot', user: 'fa-user', users: 'fa-users', clock: 'fa-clock', rotate: 'fa-rotate-right', info: 'fa-circle-info', check: 'fa-check', warning: 'fa-triangle-exclamation', comment: 'fa-comment-dots', phone: 'fa-phone', circle: 'fa-circle', hand: 'fa-hand', xmark: 'fa-xmark', 'chevron-left': 'fa-chevron-left', 'chevron-right': 'fa-chevron-right', 'arrow-left': 'fa-arrow-left', plus: 'fa-plus', minus: 'fa-minus', eye: 'fa-eye', 'eye-slash': 'fa-eye-slash', plane: 'fa-plane', house: 'fa-house', receipt: 'fa-file-invoice', money: 'fa-sack-dollar', map: 'fa-map', star: 'fa-star', chart: 'fa-chart-line', folder: 'fa-folder', filter: 'fa-filter', ticket: 'fa-ticket', 'chart-pie': 'fa-chart-pie', logout: 'fa-right-from-bracket', search: 'fa-magnifying-glass', times: 'fa-xmark' }
  i(class=`${prefix} ${icons[name] || name} icon` aria-hidden="true")

//- Icon kèm text — +faText('calendar', ' Ngày đi')
mixin faText(name, text, style)
  span.icon-text
    +fa(name, style)
    != text
